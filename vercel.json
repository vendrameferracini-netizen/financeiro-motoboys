{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/manifest.json",
      "destination": "/outputs/financeiro-motoboys/manifest.json"
    },
    {
      "source": "/sw.js",
      "destination": "/outputs/financeiro-motoboys/sw.js"
    },
    {
      "source": "/icons/:path*",
      "destination": "/outputs/financeiro-motoboys/icons/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/outputs/financeiro-motoboys/:path*"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/manifest+json; charset=utf-8"
        }
      ]
    },
    {
      "source": "/icons/:path*",
      "headers": [
        {
          "key": "Content-Type",
          "value": "image/png"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
